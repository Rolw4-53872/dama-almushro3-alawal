# ============================================
# قاعدة البيانات (SQLite)
# ============================================
DATABASE_URL="file:./dev.db"

# ============================================
# JWT
# ============================================
JWT_SECRET="your_super_secret_jwt_key_2024_change_in_production_immediately"
JWT_EXPIRATION="15m"
JWT_REFRESH_SECRET="your_super_secret_refresh_token_key_change_in_production"
JWT_REFRESH_EXPIRATION="7d"

# ============================================
# الخادم
# ============================================
NODE_ENV="development"
PORT=3000
API_PREFIX="/api/v1"

# ============================================
# AWS S3 (اختياري)
# ============================================
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key"
AWS_REGION="me-south-1"
AWS_S3_BUCKET="dama-grants-storage"

# ============================================
# البريد الإلكتروني
# ============================================
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USER="your_email@gmail.com"
MAIL_PASSWORD="your_app_password"
MAIL_FROM="noreply@dama.com"

# ============================================
# التسجيل
# ============================================
LOG_LEVEL="debug"
LOG_FILE="logs/app.log"

# ============================================
# الواجهة الأمامية
# ============================================
FRONTEND_URL="http://localhost:3001"
